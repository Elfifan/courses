// Модель пользователя (таблица users)
class User {
  final int id;
  final String name;
  final String email;
  final String password;
  final DateTime dateRegistration;
  final List<int>? avatar; // BYTEA в Dart это List<int>
  final bool status;
  final DateTime? lastEntry;

  User({
    required this.id,
    required this.name,
    required this.email,
    required this.password,
    required this.dateRegistration,
    this.avatar,
    required this.status,
    this.lastEntry,
  });

  // Конвертация из JSON (данные из Supabase)
  factory User.fromJson(Map<String, dynamic> json) {
    return User(
      id: json['id'] as int,
      name: json['name'] as String? ?? '',
      email: json['email'] as String? ?? '',
      password: json['password'] as String? ?? '',
      dateRegistration: DateTime.parse(json['date_registration'] as String),
      avatar: json['avatar'] as List<int>?,
      status: json['status'] as bool? ?? false,
      lastEntry: json['last_entry'] != null 
          ? DateTime.parse(json['last_entry'] as String)
          : null,
    );
  }

  // Конвертация в JSON (для отправки в Supabase)
  Map<String, dynamic> toJson() {
    return {
      'id': id,
      'name': name,
      'email': email,
      'password': password,
      'date_registration': dateRegistration.toIso8601String(),
      'avatar': avatar,
      'status': status,
      'last_entry': lastEntry?.toIso8601String(),
    };
  }
}

// Модель курса (таблица courses)
class Course {
  final int id;
  final int idEmployee;
  final String name;
  final String description;
  final DateTime dateCreate;
  final double price;
  final int complexity;
  final bool status;
  final int? icon;

  Course({
    required this.id,
    required this.idEmployee,
    required this.name,
    required this.description,
    required this.dateCreate,
    required this.price,
    required this.complexity,
    required this.status,
    this.icon,
  });

  factory Course.fromJson(Map<String, dynamic> json) {
    return Course(
      id: json['id'] as int,
      idEmployee: json['id_employee'] as int,
      name: json['name'] as String? ?? '',
      description: json['description'] as String? ?? '',
      dateCreate: DateTime.parse(json['date_create'] as String),
      price: (json['price'] as num?)?.toDouble() ?? 0.0,
      complexity: json['complexity'] as int? ?? 0,
      status: json['status'] as bool? ?? false,
      icon: json['icon'] as int?,
    );
  }

  Map<String, dynamic> toJson() {
    return {
      'id': id,
      'id_employee': idEmployee,
      'name': name,
      'description': description,
      'date_create': dateCreate.toIso8601String(),
      'price': price,
      'complexity': complexity,
      'status': status,
      'icon': icon,
    };
  }
}

